# Anthropic (required for resume analysis)
ANTHROPIC_API_KEY=

# Optional — Helicone LLM observability (routes Anthropic via Helicone when set)
HELICONE_API_KEY=

# Optional — PostHog analytics
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Supabase (browser + server clients)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Supabase Storage bucket for PDF resumes (create in dashboard; default: resumes)
NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET=resumes
